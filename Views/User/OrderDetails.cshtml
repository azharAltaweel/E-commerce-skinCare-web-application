                        <span class="material-symbols-outlined" style="color:var(--primary)">local_shipping</span>
                        Order Tracking
                    </div>
                    <div class="tracking-steps">
                        <div class="tracking-line"></div>
                        <div class="tracking-line-fill"></div>

                        <div class="tracking-step">
                            <div class="step-dot done">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                            </div>
                            <span class="step-label done-text">Confirmed</span>
                            <span class="step-date">May 12</span>
                        </div>
                        <div class="tracking-step">
                            <div class="step-dot done">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                            </div>
                            <span class="step-label done-text">Processing</span>
                            <span class="step-date">May 13</span>
                        </div>
                        <div class="tracking-step">
                            <div class="step-dot done">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                            </div>
                            <span class="step-label done-text">Shipped</span>
                            <span class="step-date">May 14</span>
                        </div>
                        <div class="tracking-step">
                            <div class="step-dot done">
                                <span class="material-symbols-outlined" style="font-variation-settings:'FILL' 1,'wght' 400">check</span>
                            </div>
                            <span class="step-label done-text">Delivered</span>
                            <span class="step-date">May 16</span>
                        </div>
                    </div>
                </div>

                <!-- ORDER ITEMS -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">inventory_2</span>
                        Items Ordered
                    </div>

                    <!-- Table Header (desktop) -->
                    <div class="order-table-header">
                        <span>Product</span>
                        <span class="text-center">Price</span>
                        <span class="text-center">Qty</span>
                        <span class="text-end">Total</span>
                    </div>

                    <!-- Item 1 -->
                    <div class="order-item-row">
                        <div class="d-flex gap-3 align-items-center">
                            <div class="order-item-img">
                                <img src="https://via.placeholder.com/68x86/f7f3ee/635f40?text=Serum" alt="Botanical Radiance Serum" onerror="this.src='https://via.placeholder.com/68x86/f7f3ee/635f40?text=Serum'">
                            </div>
                            <div>
                                <p class="item-name">Botanical Radiance Serum</p>
                                <p class="item-variant">30ml / Anti-Aging</p>
                            </div>
                        </div>
                        <div class="item-price">$84.00</div>
                        <div class="item-qty">× 1</div>
                        <div class="item-total">$84.00</div>
                    </div>

                    <!-- Item 2 -->
                    <div class="order-item-row">
                        <div class="d-flex gap-3 align-items-center">
                            <div class="order-item-img">
                                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAvtJTm1SUo3XrEJQMeXmNJlGEkg4r_W1w4mFo7aYfQu0evJj4mgsqiGY79ulCPJQ_tlzwB3s_wSho0tNFLSOvARf-po0Gebs6lHPn13aN0DvzWCuPimfaNSYuM7WJoyTmojdEiifNmfhv80c-TegFQU6S54BdbZ3ofuykzPVloGvZWwyd98sE5QZtXFFp61eihjFuP8ytLKbd_d554frasnjA1alRRzhI55iLMCnjV-UBBX5Wbwrap2wqW-DZn7fXA5XlWIT69dAc" alt="Cloud Hydration Cream" onerror="this.src='https://via.placeholder.com/68x86/f7f3ee/635f40?text=Cream'">
                            </div>
                            <div>
                                <p class="item-name">Cloud Hydration Cream</p>
                                <p class="item-variant">50ml / Intensive Moisture</p>
                            </div>
                        </div>
                        <div class="item-price">$62.00</div>
                        <div class="item-qty">× 1</div>
                        <div class="item-total">$62.00</div>
                    </div>

                </div><!-- /items card -->
                <!-- SHIPPING & PAYMENT INFO -->
                <div class="gc-card">
                    <div class="gc-card-title">
                        <span class="material-symbols-outlined" style="color:var(--primary)">info</span>
                        Order Information
                    </div>

                    <div class="row g-4">
                        <!-- Shipping Address -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Shipping Address</p>
                            <p class="info-value">
                                Sarah Al-Hassan<br>
                                14 Rose Garden Lane, Apt 3B<br>
                                Amman, 11183<br>
                                Jordan
                            </p>
                        </div>
                        <!-- Contact -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Contact</p>
                            <p class="info-value">
                                sarah.alhassan@email.com<br>
                                +962 79 123 4567
                            </p>
                        </div>

                        <div class="col-12"><hr class="info-divider"></div>

                        <!-- Payment Method -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Payment Method</p>
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined" style="color:var(--primary)">credit_card</span>
                                <p class="info-value mb-0">Visa ending in •••• 4821</p>
                            </div>
                        </div>
                        <!-- Shipping Method -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Shipping Method</p>
                            <div class="d-flex align-items-center gap-2">
                                <span class="material-symbols-outlined" style="color:var(--primary)">local_shipping</span>
                                <p class="info-value mb-0">
                                    Standard Delivery — Free<br>
                                    <span style="font-size:.78rem;color:var(--on-variant)">Estimated 3–5 business days</span>
                                </p>
                            </div>
                        </div>

                        <div class="col-12"><hr class="info-divider"></div>

                        <!-- Tracking Number -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Tracking Number</p>
                            <div class="d-flex align-items-center gap-2">
                                <p class="info-value mb-0" style="font-family:monospace;letter-spacing:.05em">JO-482910-GC</p>
                                <button style="background:none;border:none;color:var(--primary);cursor:pointer;padding:0" title="Copy">
                                    <span class="material-symbols-outlined" style="font-size:1rem">content_copy</span>
                                </button>
                            </div>
                        </div>
                        <!-- Order Date -->
                        <div class="col-12 col-sm-6">
                            <p class="info-label">Order Date</p>
                            <p class="info-value mb-0">Sunday, May 12, 2024 · 10:47 AM</p>
                        </div>
                    </div>
                </div>

            </div><!-- /col-lg-8 -->
            <!-- ── RIGHT COLUMN ── -->
            <div class="col-12 col-lg-4">

                <!-- Order Summary -->
                <div class="order-summary">
                    <h3 class="summary-title">Order Summary</h3>

                    <div class="summary-row">
                        <span>Subtotal (2 items)</span>
                        <span>$146.00</span>
                    </div>
                    <div class="summary-row">
                        <span>Shipping</span>
                        <span>FREE</span>
                    </div>
                    <div class="summary-row">
                        <span>Discount</span>
                        <span style="color:var(--success)">— $0.00</span>
                    </div>
                    <div class="summary-row">
                        <span>Tax (Estimated)</span>
                        <span>$12.40</span>
                    </div>

                    <div class="summary-total">
                        <span class="total-label">Total Paid</span>
                        <span class="total-value">$158.40</span>
                    </div>

                    <!-- Actions -->
                    <button class="btn-gc-primary">
                        <span class="material-symbols-outlined" style="font-size:1rem">refresh</span>
                        Buy Again
                    </button>
                    <button class="btn-gc-outline">
                        <span class="material-symbols-outlined" style="font-size:1rem">rate_review</span>
                        Write a Review
                    </button>
                    <button class="btn-gc-danger">
                        <span class="material-symbols-outlined" style="font-size:1rem">undo</span>
                        Request Return
                    </button>
                </div>

                <!-- Membership Perk -->
                <div class="promo-card">
                    <p class="promo-label">Membership Perk</p>
                    <p class="promo-text">Free samples on orders over $100</p>
                    <span class="material-symbols-outlined promo-icon">redeem</span>
                </div>

            </div><!-- /col-lg-4 -->

        </div><!-- /row -->
    </div><!-- /container -->
</main>