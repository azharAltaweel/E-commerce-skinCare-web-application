<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - GlowCare</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600;700&family=Inter:wght@400;600&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet">
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/css/UserLayout.css"
          rel="stylesheet" />
    @RenderSection("Styles", required: false)
</head>

<body>

    <!-- Announcement Bar -->
    @* <div class="bg-dark text-white text-center py-2 announcement-bar">
        Free shipping on orders over $50
    </div> *@

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light navbar-custom sticky-top py-3">
        <div class="container">

            <a class="brand" asp-controller="Home" asp-action="Index">
                GLOWCARE
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">

                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="User"
                           asp-action="Products">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">Categories</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="User"
                           asp-action="Products">Products</a>
                    </li>
                </ul>

                <!-- SEARCH FORM -->
                <form asp-controller="User"
                      asp-action="Products"
                      method="get"
                      class="d-flex me-3 search-form">

                    <input class="form-control search-box"
                           type="search"
                           name="search"
                           placeholder="Search products or categories..."
                           value="@Context.Request.Query["search"]">

                </form>

                <div class="d-flex gap-3 nav-icons">
                    <a asp-controller="User"
                       asp-action="Wishlist"
                       class="wishlist-nav">

                        <i class="bi bi-heart"></i>

                        <span id="wishlist-badge"
                              class="wishlist-badge d-none">

                            0

                        </span>
                    </a>

                    <span class="material-symbols-outlined">shopping_bag</span>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a asp-controller="Account"
                           asp-action="Profile"
                           class="profile-icon"
                           title="My Profile">

                            <span class="material-symbols-outlined">
                                person
                            </span>

                        </a>
                    }
                    else
                    {
                        <a asp-controller="Account"
                           asp-action="Login"
                           class="profile-icon"
                           title="Login / Sign Up">

                            <span class="material-symbols-outlined">
                                person
                            </span>

                        </a>
                    }
                    <span class="material-symbols-outlined cursor-pointer">favorite</span>
                    <a asp-controller="Cart" asp-action="Index" class="cart-link">
                        <span class="material-symbols-outlined cursor-pointer">shopping_bag</span>
                        <span class="cart-badge" style="display: none;">0</span>
                    </a>
                    <span class="material-symbols-outlined cursor-pointer">person</span>
                </div>

            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container py-5">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="mt-5 py-5">
        <div class="container">
            <div class="row">

                <div class="col-md-4 mb-4">
                    <h3 class="brand">GLOWCARE</h3>
                    <p>
                        Curating intentional skincare rituals for the modern individual.
                    </p>
                </div>

                <div class="col-md-2">
                    <h5 class="footer-title">Shop</h5>

                    <a href="#" class="footer-link">Shop All</a>
                    <a href="#" class="footer-link">Serums</a>
                    <a href="#" class="footer-link">Cleansers</a>
                </div>

                <div class="col-md-2">
                    <h5 class="footer-title">About</h5>

                    <a href="#" class="footer-link">Our Story</a>
                    <a href="#" class="footer-link">Blog</a>
                </div>

                <div class="col-md-2">
                    <h5 class="footer-title">Support</h5>

                    <a href="#" class="footer-link">Contact</a>
                    <a href="#" class="footer-link">Privacy Policy</a>
                </div>

            </div>

            <hr />

            <div class="text-center">
                © 2024 GlowCare. All Rights Reserved.
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>